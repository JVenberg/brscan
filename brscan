#!/usr/bin/env bash
#
# brscan - trigger a scan on a Brother DSmobile scanner (DS-640 / DS-740D /
#          DS-940DW family) over eSCL / Apple AirScan and save the result.
#
# ---------------------------------------------------------------------------
# Reverse-engineered protocol (eSCL / Apple AirScan)
# ---------------------------------------------------------------------------
# Discovery (mDNS): the scanner advertises _uscan._tcp with rs=eSCL and a SRV
#   record pointing at <host>:<port> (port 8080 on the units tested). The scan
#   API lives on that eSCL port, NOT port 80 -- the EWS admin server on :80 only
#   mirrors the read-only eSCL GETs; POST /eSCL/ScanJobs there 404s.
#
# Scan flow:
#   1. POST http://<host>:<port>/eSCL/ScanJobs   (XML ScanSettings)   -> 201
#      Response carries `Location: /eSCL/ScanJobs/<id>`.
#   2. GET  http://<host>:<port>/eSCL/ScanJobs/<id>/NextDocument      -> 200
#      Returns one JPEG per page. Repeat until 404 / connection close.
#
# Gotchas learned the hard way:
#   * These units only emit JPEG over eSCL (mDNS pdl = image/jpeg, octet-string).
#     The application/pdf in ScannerCapabilities is a template artifact; PDF is
#     assembled client-side here.
#   * They are battery/USB powered and sleep aggressively, dropping Wi-Fi. A
#     sleeping scanner will TRUNCATE a streaming scan (JPEG with no trailing
#     FFD9 and a gray tail). We therefore wake/poll first, send an explicit
#     ScanRegion with MustHonor=true so the JPEG length is fixed, and verify
#     each page is a complete JPEG (retrying once if not).
#
# Host resolution: explicit -H/BRSCAN_HOST > cached host > mDNS discovery.
#   The discovered .local name (which encodes the MAC) is cached, so later runs
#   are instant; if the cached host stops answering we auto-rediscover.
#
# No auth needed for eSCL; the web-admin password only guards the EWS UI on :80.

set -euo pipefail

# ---- defaults ---------------------------------------------------------------
HOST="${BRSCAN_HOST:-}"           # empty => use cache, else mDNS discovery
PORT="${BRSCAN_PORT:-}"           # empty => from cache/discovery, else 8080
RES="${BRSCAN_RES:-300}"          # 100|150|200|300|400|600
COLOR="${BRSCAN_COLOR:-RGB24}"    # RGB24 | Grayscale8 | BlackAndWhite1 | scan:AutoColorDetection
DUPLEX="${BRSCAN_DUPLEX:-false}"
FORMAT="${BRSCAN_FORMAT:-pdf}"    # pdf|jpeg  (output; device always sends jpeg)
INTENT="${BRSCAN_INTENT:-Document}"
SIZE="${BRSCAN_SIZE:-letter}"     # letter|a4|legal|max|auto  (auto = no region; may truncate)
WIDTH=""
HEIGHT=""
OUT=""
CROP=1                            # trim trailing scanner-background padding (1=on)
WAKE_SECS="${BRSCAN_WAKE_SECS:-25}"      # poll a sleeping scanner up to this long
DISCOVER_SECS="${BRSCAN_DISCOVER_SECS:-4}"  # mDNS browse/resolve window (dns-sd)
VERBOSE=0

CACHE_DIR="${BRSCAN_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/brscan}"
CACHE_FILE="$CACHE_DIR/scanner"   # one line: "<host> <port>"

usage() {
  cat <<'EOF'
brscan - scan from a Brother DSmobile (eSCL / AirScan) scanner over HTTP

USAGE
  brscan [options] [output-file]
  brscan --status            show scanner status (idle/busy, jobs)
  brscan --caps              dump raw ScannerCapabilities XML
  brscan --discover          find a scanner via mDNS and cache it
  brscan --forget            clear the cached scanner

OPTIONS
  -o, --out FILE       output file (default: scan-YYYYmmdd-HHMMSS.<ext>)
  -r, --res DPI        resolution: 100 150 200 300 400 600    (default 300)
  -c, --color MODE     color | gray | bw | auto               (default color)
  -f, --format FMT     pdf | jpeg                             (default pdf)
  -d, --duplex         scan both sides (if the ADF supports duplex)
  -s, --size SIZE      letter | a4 | legal | max | auto       (default letter)
      --width N        scan width  in 1/300 inch units (custom region)
      --height N       scan height in 1/300 inch units (custom region)
      --no-crop        keep the full scanned area incl. blank/gray padding
      --intent NAME    Document | Photo | Preview | TextAndGraphic
  -H, --host HOST      scanner IP or mDNS name (default: cache, then discovery)
  -P, --port N         eSCL port               (default: discovered, else 8080)
  -w, --wait SECS      poll a sleeping scanner up to SECS         (default 25)
  -v, --verbose        print request XML and HTTP details
  -h, --help           this help

NOTES
  * Sheet-fed scanner: load the page(s) in the feeder first.
  * Finds the scanner over mDNS (dns-sd on macOS, avahi-browse on Linux) and
    caches the result (~/.cache/brscan/scanner). First run needs the scanner
    powered on and on the same network. --forget clears the cache.
  * The scanner sleeps and drops Wi-Fi; brscan polls/wakes it first. If it
    won't respond, press its power button (single press) and retry.
  * Device emits JPEG. PDF is assembled locally (img2pdf / uvx img2pdf /
    ImageMagick). --crop (default) trims the gray over-scan tail.

EXAMPLES
  brscan                              # 300dpi color Letter PDF -> scan-<ts>.pdf
  brscan -d -r 600 contract.pdf       # duplex, 600dpi
  brscan -c gray -f jpeg page.jpg     # grayscale JPEG (one file per page)
  brscan -s a4 --no-crop              # full A4 area, no trimming
  brscan --discover                   # locate + cache the scanner
  brscan -H 192.168.1.50 --status     # talk to a specific host

ENV  BRSCAN_HOST BRSCAN_PORT BRSCAN_RES BRSCAN_COLOR BRSCAN_DUPLEX
     BRSCAN_FORMAT BRSCAN_INTENT BRSCAN_SIZE BRSCAN_WAKE_SECS
     BRSCAN_DISCOVER_SECS BRSCAN_CACHE_DIR
EOF
}

log()  { [ "$VERBOSE" -eq 1 ] && echo "[brscan] $*" >&2 || true; }
die()  { echo "brscan: $*" >&2; exit 1; }
note() { echo "brscan: $*" >&2; }

# ---- arg parsing ------------------------------------------------------------
ACTION="scan"
while [ $# -gt 0 ]; do
  case "$1" in
    -o|--out)     OUT="$2"; shift 2 ;;
    -r|--res)     RES="$2"; shift 2 ;;
    -c|--color)   COLOR="$2"; shift 2 ;;
    -f|--format)  FORMAT="$2"; shift 2 ;;
    -d|--duplex)  DUPLEX=true; shift ;;
    -s|--size)    SIZE="$2"; shift 2 ;;
    --width)      WIDTH="$2"; shift 2 ;;
    --height)     HEIGHT="$2"; shift 2 ;;
    --no-crop)    CROP=0; shift ;;
    --crop)       CROP=1; shift ;;
    --intent)     INTENT="$2"; shift 2 ;;
    -H|--host)    HOST="$2"; shift 2 ;;
    -P|--port)    PORT="$2"; shift 2 ;;
    -w|--wait)    WAKE_SECS="$2"; shift 2 ;;
    -v|--verbose) VERBOSE=1; shift ;;
    --status)     ACTION="status"; shift ;;
    --caps)       ACTION="caps"; shift ;;
    --discover)   ACTION="discover"; shift ;;
    --forget)     ACTION="forget"; shift ;;
    -h|--help)    usage; exit 0 ;;
    -*)           die "unknown option: $1 (try --help)" ;;
    *)            OUT="$1"; shift ;;
  esac
done

# Was a host pinned explicitly (flag or env)? If so, skip cache + discovery.
HOST_EXPLICIT=0; [ -n "$HOST" ] && HOST_EXPLICIT=1

case "$COLOR" in
  color|rgb|RGB)             COLOR=RGB24 ;;
  gray|grey|grayscale|Gray)  COLOR=Grayscale8 ;;
  bw|mono|BlackAndWhite)     COLOR=BlackAndWhite1 ;;
  auto|Auto)                 COLOR="scan:AutoColorDetection" ;;
esac

# ---- discovery + cache ------------------------------------------------------
probe_status() {  # probe_status <host> <port> <timeout> ; 0 if eSCL answers 200
  local code
  code="$(curl -s -o /dev/null -w '%{http_code}' -m "$3" "http://$1:$2/eSCL/ScannerStatus" 2>/dev/null || echo 000)"
  [ "$code" = "200" ]
}

write_cache() {  # write_cache <host> <port>
  mkdir -p "$CACHE_DIR" 2>/dev/null || true
  printf '%s %s\n' "$1" "$2" > "$CACHE_FILE" 2>/dev/null || true
}

discover_scanner() {  # echo "<host> <port>" for the first _uscan._tcp scanner; 1 if none
  local host port line inst btmp ltmp bpid lpid

  # Linux: avahi-browse resolves + dumps in one parseable shot.
  if command -v avahi-browse >/dev/null 2>&1; then
    line="$(avahi-browse -rtp _uscan._tcp 2>/dev/null | awk -F';' '/^=/{print $7" "$9; exit}')" || true
    if [ -n "${line:-}" ]; then
      host="${line%% *}"; port="${line##* }"; host="${host%.}"
      [ -n "$host" ] && [ -n "$port" ] && { echo "$host $port"; return 0; }
    fi
  fi

  # macOS: dns-sd runs until killed, so browse then resolve with a time box.
  if command -v dns-sd >/dev/null 2>&1; then
    btmp="$(mktemp)"
    dns-sd -B _uscan._tcp local. >"$btmp" 2>/dev/null & bpid=$!
    sleep "$DISCOVER_SECS"; kill "$bpid" 2>/dev/null || true; wait "$bpid" 2>/dev/null || true
    inst="$(grep -F ' Add ' "$btmp" | sed -n 's/.*_uscan\._tcp\.[[:space:]]*//p' | sed 's/[[:space:]]*$//' | sed '/^$/d' | head -1)"
    rm -f "$btmp"
    [ -n "$inst" ] || return 1
    ltmp="$(mktemp)"
    dns-sd -L "$inst" _uscan._tcp local. >"$ltmp" 2>/dev/null & lpid=$!
    sleep "$DISCOVER_SECS"; kill "$lpid" 2>/dev/null || true; wait "$lpid" 2>/dev/null || true
    line="$(sed -n 's/.*can be reached at \([^ ]*\):\([0-9][0-9]*\).*/\1 \2/p' "$ltmp" | head -1)"
    rm -f "$ltmp"
    if [ -n "${line:-}" ]; then
      host="${line%% *}"; port="${line##* }"; host="${host%.}"
      [ -n "$host" ] && [ -n "$port" ] && { echo "$host $port"; return 0; }
    fi
  fi
  return 1
}

# Resolve HOST/PORT/BASE: explicit > cache (quick probe) > discovery > wake-poll.
locate_scanner() {  # locate_scanner <wait_secs> ; sets HOST PORT BASE or returns 1
  local wait_secs="$1" cand_host="" cand_port="" found deadline
  if [ "$HOST_EXPLICIT" -eq 1 ]; then
    cand_host="$HOST"; cand_port="${PORT:-8080}"
  else
    if [ -f "$CACHE_FILE" ]; then
      read -r cand_host cand_port < "$CACHE_FILE" 2>/dev/null || true
      [ -n "$cand_host" ] && log "cached scanner: ${cand_host}:${cand_port:-8080}" || true
    fi
    [ -n "$cand_port" ] || cand_port="${PORT:-8080}"
  fi

  # 1) quick probe of the known candidate
  if [ -n "$cand_host" ] && probe_status "$cand_host" "$cand_port" 4; then
    HOST="$cand_host"; PORT="$cand_port"; BASE="http://${HOST}:${PORT}/eSCL"; return 0
  fi

  # 2) mDNS discovery (first run / IP or name changed). Not for explicit -H.
  if [ "$HOST_EXPLICIT" -ne 1 ]; then
    note "discovering scanner via mDNS (_uscan._tcp)..."
    found="$(discover_scanner || true)"
    if [ -n "${found:-}" ]; then
      cand_host="${found%% *}"; cand_port="${found##* }"
      note "found ${cand_host}:${cand_port}"
      write_cache "$cand_host" "$cand_port"
      if probe_status "$cand_host" "$cand_port" 4; then
        HOST="$cand_host"; PORT="$cand_port"; BASE="http://${HOST}:${PORT}/eSCL"; return 0
      fi
    fi
  fi

  # 3) wake-poll the candidate (it may simply be asleep)
  if [ -n "$cand_host" ]; then
    note "waiting for ${cand_host}:${cand_port} to respond (it sleeps to save power)..."
    deadline=$(( SECONDS + wait_secs ))
    while [ "$SECONDS" -lt "$deadline" ]; do
      if probe_status "$cand_host" "$cand_port" 4; then
        HOST="$cand_host"; PORT="$cand_port"; BASE="http://${HOST}:${PORT}/eSCL"; return 0
      fi
      sleep 2
    done
  fi
  return 1
}

NO_SCANNER_MSG="no scanner reachable. Power it on (single press) and ensure it is on the same Wi-Fi/subnet; first run needs mDNS (dns-sd on macOS, avahi-browse on Linux). Or pass -H <ip>."

# ---- cache-only actions -----------------------------------------------------
if [ "$ACTION" = "forget" ]; then
  rm -f "$CACHE_FILE" 2>/dev/null || true
  note "cleared cached scanner ($CACHE_FILE)"; exit 0
fi
if [ "$ACTION" = "discover" ]; then
  found="$(discover_scanner || true)"
  [ -n "${found:-}" ] || die "$NO_SCANNER_MSG"
  h="${found%% *}"; p="${found##* }"
  write_cache "$h" "$p"
  note "found and cached: ${h}:${p}  (cache: $CACHE_FILE)"; exit 0
fi

# ---- read-only actions ------------------------------------------------------
if [ "$ACTION" = "caps" ] || [ "$ACTION" = "status" ]; then
  locate_scanner "$WAKE_SECS" || die "$NO_SCANNER_MSG"
  if [ "$ACTION" = "caps" ]; then curl -fsS -m 15 "$BASE/ScannerCapabilities"; echo; exit 0; fi
  curl -fsS -m 15 "$BASE/ScannerStatus"; echo; exit 0
fi

# ---- output format ----------------------------------------------------------
case "$FORMAT" in
  pdf)       EXT="pdf" ;;
  jpeg|jpg)  FORMAT="jpeg"; EXT="jpg" ;;
  *) die "unknown --format '$FORMAT' (pdf|jpeg)" ;;
esac

TS="$(date +%Y%m%d-%H%M%S)"
[ -n "$OUT" ] || OUT="scan-${TS}.${EXT}"
OUTDIR="$(cd "$(dirname "$OUT")" && pwd)"
OUTBASE="$(basename "$OUT")"
OUTNAME="${OUTBASE%.*}"

# ---- scan region (units = 1/300 inch). MustHonor=true => fixed JPEG length. --
REGION_XML=""
if [ "$SIZE" != "auto" ] || [ -n "$WIDTH" ] || [ -n "$HEIGHT" ]; then
  if [ -z "$WIDTH" ] || [ -z "$HEIGHT" ]; then
    case "$SIZE" in
      letter) WIDTH=${WIDTH:-2550}; HEIGHT=${HEIGHT:-3300} ;;
      a4)     WIDTH=${WIDTH:-2480}; HEIGHT=${HEIGHT:-3508} ;;
      legal)  WIDTH=${WIDTH:-2550}; HEIGHT=${HEIGHT:-4200} ;;
      max)    WIDTH=${WIDTH:-2550}; HEIGHT=${HEIGHT:-4200} ;;
      auto)   : ;;  # custom width/height only
      *) die "unknown --size '$SIZE' (letter|a4|legal|max|auto)" ;;
    esac
  fi
  REGION_XML="<pwg:ScanRegions pwg:MustHonor=\"true\">
    <pwg:ScanRegion>
      <pwg:ContentRegionUnits>escl:ThreeHundredthsOfInches</pwg:ContentRegionUnits>
      <pwg:Height>${HEIGHT}</pwg:Height>
      <pwg:Width>${WIDTH}</pwg:Width>
      <pwg:XOffset>0</pwg:XOffset>
      <pwg:YOffset>0</pwg:YOffset>
    </pwg:ScanRegion>
  </pwg:ScanRegions>"
fi

read -r -d '' BODY <<EOF || true
<?xml version="1.0" encoding="UTF-8"?>
<scan:ScanSettings xmlns:pwg="http://www.pwg.org/schemas/2010/12/sm" xmlns:scan="http://schemas.hp.com/imaging/escl/2011/05/03">
  <pwg:Version>2.63</pwg:Version>
  <scan:Intent>${INTENT}</scan:Intent>
  ${REGION_XML}
  <pwg:InputSource>Feeder</pwg:InputSource>
  <scan:Duplex>${DUPLEX}</scan:Duplex>
  <scan:ColorMode>${COLOR}</scan:ColorMode>
  <scan:XResolution>${RES}</scan:XResolution>
  <scan:YResolution>${RES}</scan:YResolution>
  <scan:BlankPageDetection>true</scan:BlankPageDetection>
  <pwg:DocumentFormat>image/jpeg</pwg:DocumentFormat>
  <scan:DocumentFormatExt>image/jpeg</scan:DocumentFormatExt>
</scan:ScanSettings>
EOF

log "request body:"; [ "$VERBOSE" -eq 1 ] && echo "$BODY" >&2

HDR="$(mktemp -t brscan-hdr.XXXXXX)"
PAGEDIR="$(mktemp -d -t brscan-pages.XXXXXX)"
trap 'rm -rf "$HDR" "$PAGEDIR"' EXIT

# ---- 0. locate / wake the scanner ------------------------------------------
locate_scanner "$WAKE_SECS" || die "$NO_SCANNER_MSG"

# ---- 1. create the scan job -------------------------------------------------
note "scanning on ${HOST}:${PORT}  (${COLOR##*:} ${RES}dpi $([ "$DUPLEX" = true ] && echo duplex || echo simplex), ${SIZE} -> ${FORMAT})"
HTTP_CODE="$(curl -sS -m 60 -o /dev/null -D "$HDR" -w '%{http_code}' \
  -X POST "$BASE/ScanJobs" -H "Content-Type: text/xml" --data-binary "$BODY")" \
  || die "could not reach scanner at ${HOST}:${PORT}"
log "POST /eSCL/ScanJobs -> $HTTP_CODE"; [ "$VERBOSE" -eq 1 ] && cat "$HDR" >&2

if [ "$HTTP_CODE" != "201" ]; then
  case "$HTTP_CODE" in
    409) die "scanner busy or no paper in the feeder (HTTP 409). Load a page and retry." ;;
    503) die "scanner unavailable / in use by another client (HTTP 503)." ;;
    404) die "ScanJobs not found on ${HOST}:${PORT}. Wrong eSCL port? (try -P 8080)" ;;
    *)   echo "----- response -----" >&2; cat "$HDR" >&2; die "ScanJobs creation failed (HTTP $HTTP_CODE)." ;;
  esac
fi

LOCATION="$(grep -i '^location:' "$HDR" | tr -d '\r' | tail -1 | sed 's/^[Ll]ocation:[[:space:]]*//')"
[ -n "$LOCATION" ] || die "no Location header returned; cannot fetch document."
case "$LOCATION" in
  http*) JOB="$LOCATION" ;;
  /*)    JOB="http://${HOST}:${PORT}${LOCATION}" ;;
  *)     JOB="http://${HOST}:${PORT}/${LOCATION}" ;;
esac
log "job: $JOB"

# A complete JPEG ends with the EOI marker FFD9. A truncated transfer (sleeping
# scanner) won't, so we can detect and retry.
jpeg_complete() { [ -s "$1" ] && [ "$(tail -c 2 "$1" | xxd -p)" = "ffd9" ]; }

fetch_page() {  # fetch_page <dest>  -> 0 ok / 1 no-more / 2 incomplete
  local dest="$1" code
  code="$(curl -sS --speed-limit 1024 --speed-time 30 -m 300 \
          -o "$dest" -w '%{http_code}' "${JOB}/NextDocument" 2>/dev/null)" || code="000"
  local bytes; bytes=$( [ -f "$dest" ] && wc -c <"$dest" | tr -d ' ' || echo 0 )
  log "GET NextDocument -> $code (${bytes} bytes)"
  if [ "$code" = "200" ] && [ "${bytes:-0}" -gt 0 ]; then
    jpeg_complete "$dest" && return 0 || return 2
  fi
  rm -f "$dest"; return 1
}

# ---- 2. pull pages ----------------------------------------------------------
page=0
while :; do
  page=$((page + 1))
  pf="$(printf '%s/page-%03d.jpg' "$PAGEDIR" "$page")"
  if fetch_page "$pf"; then
    note "received page $page ($(wc -c <"$pf" | tr -d ' ') bytes)"
  else
    rc=$?
    if [ "$rc" = "2" ]; then
      note "page $page came back truncated (scanner likely slept mid-transfer); retrying once..."
      if fetch_page "$pf"; then
        note "received page $page on retry ($(wc -c <"$pf" | tr -d ' ') bytes)"
      else
        note "WARNING: page $page still incomplete; keeping the partial image."
        [ -f "$pf" ] || page=$((page - 1))
      fi
    else
      page=$((page - 1)); break
    fi
  fi
  # safety stop
  [ "$page" -ge 200 ] && break
done

shopt -s nullglob
PAGES=( "$PAGEDIR"/page-*.jpg )
[ "${#PAGES[@]}" -gt 0 ] || die "scanner accepted the job but returned no pages (empty feeder?)."

# ---- 3. optional crop of trailing scanner-background ------------------------
crop_page() {  # crop_page <jpg> ; trims uniform blank/gray padding in place
  command -v magick >/dev/null 2>&1 || return 0
  local f="$1" bg
  bg="$(magick "$f" -format '%[pixel:p{2,%[fx:h-2]}]' info: 2>/dev/null)" || return 0
  magick "$f" -bordercolor "$bg" -border 1 -fuzz 8% -trim +repage "$f" 2>/dev/null || true
}
if [ "$CROP" -eq 1 ]; then
  for f in "${PAGES[@]}"; do crop_page "$f"; done
fi

# ---- 4. write output --------------------------------------------------------
assemble_pdf() {  # assemble_pdf <out.pdf> <jpg...>
  local out="$1"; shift
  if   command -v img2pdf >/dev/null 2>&1; then img2pdf "$@" -o "$out"
  elif command -v uvx     >/dev/null 2>&1; then uvx img2pdf "$@" -o "$out"
  elif command -v magick  >/dev/null 2>&1; then magick "$@" "$out"
  elif command -v convert >/dev/null 2>&1; then convert "$@" "$out"
  else return 2
  fi
}

if [ "$FORMAT" = "pdf" ]; then
  DEST="${OUTDIR}/${OUTBASE}"
  if assemble_pdf "$DEST" "${PAGES[@]}"; then
    note "saved $DEST  (${#PAGES[@]} page(s))"
  else
    note "no PDF tool found (img2pdf/uvx/imagemagick); saving JPEG pages instead."
    i=0; for f in "${PAGES[@]}"; do i=$((i+1)); d="${OUTDIR}/${OUTNAME}-p$(printf '%02d' "$i").jpg"; cp "$f" "$d"; note "saved $d"; done
  fi
else
  if [ "${#PAGES[@]}" -eq 1 ]; then
    cp "${PAGES[0]}" "${OUTDIR}/${OUTBASE}"; note "saved ${OUTDIR}/${OUTBASE}"
  else
    i=0; for f in "${PAGES[@]}"; do i=$((i+1)); d="${OUTDIR}/${OUTNAME}-p$(printf '%02d' "$i").jpg"; cp "$f" "$d"; note "saved $d"; done
  fi
fi
